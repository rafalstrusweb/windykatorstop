# Skopiuj ten plik jako .env.local i uzupelnij klucze.

# Anthropic API - dla asystenta AI w /
ANTHROPIC_API_KEY=sk-ant-...

# Resend API - opcjonalne, do wysylki leadow i zgloszen prawnikow/pracodawcow.
# Bez tych zmiennych zgloszenia leca do logow konsoli (widoczne w Vercel dashboard).
RESEND_API_KEY=re_...
ADMIN_EMAIL=pomoc@windykatorstop.pl

# Plausible Analytics - cookieless, RODO-friendly
# Skrypt jest wbudowany domyslnie (zobacz components/Analytics.tsx).
# Aby wylaczyc na konkretnym srodowisku (np. preview/dev):
# NEXT_PUBLIC_DISABLE_ANALYTICS=true
# Aby nadpisac skrypt (np. self-hosted Plausible):
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT=https://twoj-plausible.pl/js/script.js
